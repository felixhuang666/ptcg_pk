# Google OAuth
APP_URL="https://felix9977.mooo.com"
#GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=GOCSPX-xxxxx
GOOGLE_CLIENT_SECRET=

# DATABASE configuration, goto superbase, project, setting, api key
SUPABASE_URL="https://your-project-id.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Backend configuration
APP_BACKEND_PORT=5000

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

# Enable full screen notification by default
VITE_ENABLE_FULL_SCREEN_NOTIFICATION=true

# RPG Camera Size (number of cells in each direction)
VITE_RPG_CAMERA_SIZE=10
